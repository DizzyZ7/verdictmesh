APP_NAME=VerdictMesh
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

TRADING_MODE=paper
LIVE_TRADING_ENABLED=false

DATABASE_URL=postgresql+psycopg://verdictmesh:verdictmesh@db:5432/verdictmesh
DATABASE_ECHO=false
DATABASE_AUTO_CREATE=false

GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
MARKET_SCAN_LIMIT=100
ORDER_BOOK_SCANNER_ENABLED=true
ORDER_BOOK_SCAN_INTERVAL_SECONDS=60
ORDER_BOOK_SCAN_CONCURRENCY=10
ORDER_BOOK_MARKET_LIMIT=50
ORDER_BOOK_ASSET_LIMIT=100

GDELT_API_URL=https://api.gdeltproject.org
EVIDENCE_SEARCH_TIMESPAN=1week
EVIDENCE_SEARCH_MAX_RECORDS=75
EVIDENCE_MAX_ITEMS=8
EVIDENCE_MIN_ITEMS=2
EVIDENCE_QUERY_MAX_TERMS=8

ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com
FORECAST_MODEL=claude-sonnet-4-6
FORECAST_MAX_TOKENS=2500
FORECAST_MIN_AGENTS=3
FORECAST_MIN_EVIDENCE=2
FORECAST_MIN_COVERAGE=0.50
FORECAST_MIN_EVIDENCE_QUALITY=0.55
FORECAST_MIN_CONFIDENCE=0.65
FORECAST_MAX_DISAGREEMENT=0.15
FORECAST_MIN_RESOLUTION_CLARITY=0.75
FORECAST_MIN_ACTIONABLE_EDGE=0.07

PAPER_STARTING_CASH=10000
MIN_NET_EDGE=0.07
MIN_CONFIDENCE=0.70
MIN_LIQUIDITY_USD=10000
MAX_SPREAD=0.025
MAX_POSITION_FRACTION=0.01
MAX_TOTAL_EXPOSURE_FRACTION=0.10
MAX_DAILY_LOSS_FRACTION=0.02
