APP_NAME=VerdictMesh
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

TRADING_MODE=paper
LIVE_TRADING_ENABLED=false

DATABASE_URL=postgresql+psycopg://verdictmesh:verdictmesh@db:5432/verdictmesh
DATABASE_ECHO=false
DATABASE_AUTO_CREATE=false

GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
MARKET_SCAN_LIMIT=100
ORDER_BOOK_SCANNER_ENABLED=true
ORDER_BOOK_SCAN_INTERVAL_SECONDS=60
ORDER_BOOK_SCAN_CONCURRENCY=10
ORDER_BOOK_MARKET_LIMIT=50
ORDER_BOOK_ASSET_LIMIT=100

PAPER_STARTING_CASH=10000
MIN_NET_EDGE=0.07
MIN_CONFIDENCE=0.70
MIN_LIQUIDITY_USD=10000
MAX_SPREAD=0.025
MAX_POSITION_FRACTION=0.01
MAX_TOTAL_EXPOSURE_FRACTION=0.10
MAX_DAILY_LOSS_FRACTION=0.02

ANTHROPIC_API_KEY=
